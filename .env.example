# Copy to `.env` and fill in the keys you need. Loaded automatically if
# `python-dotenv` is installed (pip install -e ".[dotenv]").
# NEVER commit your real .env.

# OpenAI-compatible models (OpenRouter / OpenAI / DashScope ...): GPT, Qwen, Gemma
OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# Gemini native (provider: gemini)
# GEMINI_API_KEY=

# fal.ai hosted models (provider: fal)
# FAL_KEY=

# Hugging Face token — only for a gated/private dataset or higher rate limits.
# The public yzzyu/UFO dataset does NOT require a token.
# HF_TOKEN=
